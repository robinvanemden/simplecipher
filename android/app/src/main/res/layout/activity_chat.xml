<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true"
    android:importantForAutofill="noExcludeDescendants">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_connecting"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- SAS verification (hidden until handshake completes) -->
    <LinearLayout
        android:id="@+id/sasLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:gravity="center"
        android:padding="32dp">

        <!-- Lock icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="\uD83D\uDD10"
            android:textSize="32sp"
            android:contentDescription="Lock icon"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sas_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sas_instruction"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="24dp" />

        <!-- SAS code display -->
        <TextView
            android:id="@+id/sasCodeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@color/accent"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:contentDescription="Safety code"
            android:layout_marginBottom="24dp" />

        <!-- SAS input — showSoftInputOnFocus="false" prevents the system
             keyboard from appearing; our custom SimpleKeyboard handles input
             instead, so keystrokes never leave our process. -->
        <EditText
            android:id="@+id/sasInput"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:hint="@string/sas_hint"
            android:inputType="textCapCharacters|textNoSuggestions|textVisiblePassword"
            android:imeOptions="actionDone"
            android:importantForAutofill="no"
            android:privateImeOptions="nm,com.google.android.inputmethod.latin.noMicrophoneKey"
            android:filterTouchesWhenObscured="true"
            android:focusableInTouchMode="true"
            android:maxLength="9"
            android:fontFamily="monospace"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:gravity="center"
            android:letterSpacing="0.3"
            android:background="@drawable/bg_input"
            android:contentDescription="Type the full safety code to confirm"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/sasConfirmBtn"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:text="@string/sas_confirm"
            android:textSize="14sp"
            android:textColor="#FF0D0D0D"
            android:textStyle="bold"
            android:background="@drawable/bg_button"
            android:textAllCaps="false"
            android:contentDescription="Confirm safety code"
            android:filterTouchesWhenObscured="true" />
    </LinearLayout>

    <!-- Chat area (hidden until SAS verified) -->
    <LinearLayout
        android:id="@+id/chatLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Chat log -->
        <TextView
            android:id="@+id/chatLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:lineSpacingExtra="3dp"
            android:scrollbars="vertical"
            android:textIsSelectable="false"
            android:longClickable="false"
            android:background="@drawable/bg_chat_log"
            android:contentDescription="Chat messages"
            android:layout_margin="12dp" />

        <!-- Input bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <!-- showSoftInputOnFocus="false" suppresses the system keyboard;
                 our custom SimpleKeyboard injects text directly, keeping
                 keystrokes inside our process and away from the IME. -->
            <EditText
                android:id="@+id/chatInput"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="@string/chat_hint"
                android:inputType="text|textNoSuggestions|textVisiblePassword"
                android:imeOptions="actionSend"
                android:importantForAutofill="no"
                android:privateImeOptions="nm,com.google.android.inputmethod.latin.noMicrophoneKey"
                android:filterTouchesWhenObscured="true"
                    android:focusableInTouchMode="true"
                android:maxLines="1"
                android:maxLength="486"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:background="@drawable/bg_input"
                android:contentDescription="Type a message" />

            <Button
                android:id="@+id/sendBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="@string/btn_send_icon"
                android:textSize="18sp"
                android:textColor="#FF0D0D0D"
                android:background="@drawable/bg_send_button"
                android:layout_marginStart="10dp"
                android:textAllCaps="false"
                android:contentDescription="Send message" />
        </LinearLayout>
    </LinearLayout>

    <!-- In-app keyboard (prevents system IME keystroke logging).
         Keystrokes go directly from this View into the EditText via
         getText().insert(), never touching the InputMethodService pipeline.
         See SimpleKeyboard.java for full rationale. -->
    <com.example.simplecipher.SimpleKeyboard
        android:id="@+id/inAppKeyboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

</LinearLayout>
