<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="32dp"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true"
    android:importantForAutofill="noExcludeDescendants">

    <!-- App identity -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:letterSpacing="0.05"
        android:layout_marginTop="48dp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tagline"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="48dp" />

    <!-- Mode toggle -->
    <RadioGroup
        android:id="@+id/modeGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_mode_toggle"
        android:padding="4dp"
        android:layout_marginBottom="20dp">

        <RadioButton
            android:id="@+id/radioListen"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="@string/mode_listen"
            android:textSize="14sp"
            android:textColor="@color/text_radio_button"
            android:button="@null"
            android:gravity="center"
            android:background="@drawable/bg_radio_button"
            android:filterTouchesWhenObscured="true"
            android:saveEnabled="false"
            android:checked="true" />

        <RadioButton
            android:id="@+id/radioConnect"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="@string/mode_connect"
            android:textSize="14sp"
            android:textColor="@color/text_radio_button"
            android:button="@null"
            android:gravity="center"
            android:background="@drawable/bg_radio_button"
            android:filterTouchesWhenObscured="true"
            android:saveEnabled="false"
            android:layout_marginStart="4dp" />
    </RadioGroup>

    <!-- Connect label (Connect mode only) -->
    <TextView
        android:id="@+id/connectLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Connect to remote IP"
        android:textSize="12sp"
        android:textColor="@color/text_hint"
        android:paddingStart="4dp"
        android:paddingBottom="8dp"
        android:visibility="gone" />

    <!-- Host input (Connect mode only)
         Peer IPs/hosts are sensitive metadata in this threat model:
         they reveal who you talked to.  Suppress keyboard suggestions,
         autofill, and prediction to avoid caching them. -->
    <EditText
        android:id="@+id/hostInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_host"
        android:inputType="text|textNoSuggestions|textVisiblePassword"
        android:importantForAutofill="no"
        android:saveEnabled="false"
        android:privateImeOptions="nm,com.google.android.inputmethod.latin.noMicrophoneKey"
        android:filterTouchesWhenObscured="true"
        android:textSize="15sp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:background="@drawable/bg_input"
        android:visibility="gone"
        android:layout_marginBottom="12dp" />

    <!-- Local IPs (Listen mode only) -->
    <LinearLayout
        android:id="@+id/localIpsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="12dp" />

    <!-- Port input (same metadata-sensitivity as host) -->
    <EditText
        android:id="@+id/portInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_port"
        android:inputType="number"
        android:importantForAutofill="no"
        android:saveEnabled="false"
        android:privateImeOptions="nm,com.google.android.inputmethod.latin.noMicrophoneKey"
        android:filterTouchesWhenObscured="true"
        android:maxLength="5"
        android:textSize="15sp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:background="@drawable/bg_input"
        android:contentDescription="Port number"
        android:layout_marginBottom="12dp" />

    <!-- Advanced section (collapsible, for SOCKS5 proxy) -->
    <LinearLayout
        android:id="@+id/advancedSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/advancedToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/advanced_section_title"
            android:textSize="14sp"
            android:textColor="@color/text_hint"
            android:paddingTop="4dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:id="@+id/advancedContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- SOCKS5 proxy (optional, for Tor via Orbot).
                 Same security treatment as host/port: no autofill,
                 no suggestions, no IME learning, custom keyboard. -->
            <EditText
                android:id="@+id/socks5Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_socks5"
                android:inputType="textNoSuggestions|textVisiblePassword"
                android:importantForAutofill="no"
                android:saveEnabled="false"
                android:privateImeOptions="nm,com.google.android.inputmethod.latin.noMicrophoneKey"
                android:maxLength="64"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:background="@drawable/bg_input"
                android:contentDescription="SOCKS5 proxy address"
                android:filterTouchesWhenObscured="true"
                android:layout_marginBottom="8dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Fingerprint verification (collapsible, collapsed by default) -->
    <LinearLayout
        android:id="@+id/fpSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <!-- Toggle header -->
        <TextView
            android:id="@+id/fpToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/fp_section_title"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:drawableStart="@android:drawable/arrow_down_float"
            android:drawablePadding="8dp"
            android:paddingStart="4dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <!-- Expandable content (hidden by default) -->
        <LinearLayout
            android:id="@+id/fpContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingTop="8dp">

            <!-- QR code display -->
            <ImageView
                android:id="@+id/fpQrImage"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center_horizontal"
                android:scaleType="fitCenter"
                android:contentDescription="@string/fp_session_label" />

            <!-- Fingerprint text below QR -->
            <TextView
                android:id="@+id/fpSelfText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:typeface="monospace"
                android:letterSpacing="0.05"
                android:paddingTop="8dp"
                android:paddingBottom="16dp" />

            <!-- Scan button -->
            <Button
                android:id="@+id/fpScanBtn"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="@string/fp_scan_btn"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_input"
                android:textAllCaps="false"
                android:filterTouchesWhenObscured="true"
                android:layout_marginBottom="8dp" />

            <!-- Manual text input fallback -->
            <EditText
                android:id="@+id/fpManualInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/fp_manual_hint"
                android:inputType="text|textNoSuggestions|textVisiblePassword|textCapCharacters"
                android:importantForAutofill="no"
                android:saveEnabled="false"
                android:privateImeOptions="nm,com.google.android.inputmethod.latin.noMicrophoneKey"
                android:filterTouchesWhenObscured="true"
                android:maxLength="19"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:typeface="monospace"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="8dp" />

            <!-- Peer fingerprint status -->
            <TextView
                android:id="@+id/fpPeerStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fp_peer_none"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:paddingStart="4dp" />

            <!-- Trust fingerprint: skip safety code if fingerprint matches -->
            <CheckBox
                android:id="@+id/fpTrustCheckbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fp_trust_label"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:paddingTop="8dp"
                android:visibility="gone"
                android:filterTouchesWhenObscured="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- Start button -->
    <Button
        android:id="@+id/goButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/btn_go"
        android:textSize="15sp"
        android:textColor="#FF0D0D0D"
        android:textStyle="bold"
        android:background="@drawable/bg_button"
        android:textAllCaps="false"
        android:filterTouchesWhenObscured="true" />

    <!-- Spacer pushes footer to bottom -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Custom in-app keyboard — replaces system IME for all inputs.
         Prevents third-party keyboards from seeing host, port, or
         fingerprint data.  Same keyboard used by ChatActivity. -->
    <com.example.simplecipher.SimpleKeyboard
        android:id="@+id/mainKeyboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <!-- Footer -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/footer"
        android:textSize="11sp"
        android:textColor="@color/text_hint"
        android:layout_marginBottom="8dp" />

</LinearLayout>
