<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ data extraction rules: disallow all cloud and device backup. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
