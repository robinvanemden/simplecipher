# SimpleCipher C code style — K&R with 4-space indent.
#
# Matches the existing codebase conventions:
#   - Opening brace on same line (K&R / "attach")
#   - 4-space indentation, no tabs
#   - /* */ block comments only (no //)
#   - Pointer: int *p (asterisk with the name)
#   - Column-aligned struct fields, variable declarations, and assignments
#   - Compact one-liner functions and error handlers
#   - Hand-formatted BPF tables and crypto_wipe groups (use clang-format off)
#
# Enforced in CI: clang-format-19 --dry-run -Werror src/*.c src/*.h
# Sections that need hand formatting use // clang-format off/on guards.

BasedOnStyle: LLVM

IndentWidth: 4
UseTab: Never
ColumnLimit: 120

# K&R brace style: opening brace on same line
BreakBeforeBraces: Attach

# Pointer alignment: int *p (not int* p)
PointerAlignment: Right

# Space after keywords, not after function names
SpaceBeforeParens: ControlStatements

# Allow compact one-liners (the codebase uses these extensively)
AllowShortFunctionsOnASingleLine: All
AllowShortIfStatementsOnASingleLine: AllIfsAndElse
AllowShortLoopsOnASingleLine: true
AllowShortBlocksOnASingleLine: Always

# Preserve column-aligned declarations and assignments
AlignConsecutiveDeclarations: true
AlignConsecutiveAssignments: true

# Don't reflow comments (preserve hand-written doc blocks)
ReflowComments: false

# Don't reorder includes (groups are deliberate)
SortIncludes: Never
IncludeBlocks: Preserve

# Preprocessor indentation: match existing style
IndentPPDirectives: AfterHash
